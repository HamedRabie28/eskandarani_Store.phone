{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": ["node"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@prisma/client": ["../node_modules/.prisma/client"],
      "@prisma/client/*": ["../node_modules/.prisma/client/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["seed.ts"],
  "exclude": ["../node_modules"]
}
