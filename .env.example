# ============================================================
# Askandarani Phone — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# ============================================================

# --- Database (Required) ---
DATABASE_URL="postgresql://user:password@host:5432/askandarani"

# --- Resend Email (Phase 3 - Notifications) ---
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=""

# --- Paymob (Phase 2 - Payment Webhooks) ---
# Your Paymob HMAC secret for webhook signature verification
PAYMOB_HMAC_SECRET=""
# Your Paymob API key for initiating payments
PAYMOB_API_KEY=""
# Your Paymob Integration ID for the payment iframe
PAYMOB_INTEGRATION_ID=""
# Optional return URL after Paymob payment completes
PAYMOB_RETURN_URL=""

# --- App Settings ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
