# Askandarani Phone — Environment Variables
# ============================================
# This file is used for LOCAL development.
# For VERCEL: add DATABASE_PROVIDER and DATABASE_URL in Vercel Dashboard → Settings → Environment Variables

# Local development uses SQLite by default.
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# For local PostgreSQL development, uncomment and configure:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://postgres:password@localhost:5432/askandarani"

# Seeded admin login (when running npm run seed):
# ADMIN_EMAIL=admin@askandarani.phone
# ADMIN_PASSWORD=admin123
